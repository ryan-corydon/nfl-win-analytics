  "visual": {
    "visualType": "textbox",
    "objects": {
      "general": [
        {
          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "Glossary — How to Read This Dashboard",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "28pt",
                      "color": "#14181f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "No football knowledge required — here's what the key stats on this dashboard mean.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "16pt",
                      "color": "#5b6472"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "8px"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "EPA (Expected Points Added):  ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "14pt",
                      "color": "#4f46e5"
                    }
                  },
                  {
                    "value": "Measures how much a single play is worth in points, based on the down, distance, and field position. A positive number means the play helped the team more than expected; negative means it hurt. This is the single most important stat on this dashboard — it's the strongest predictor of whether a team wins.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "14pt",
                      "color": "#14181f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Success Rate:  ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "14pt",
                      "color": "#4f46e5"
                    }
                  },
                  {
                    "value": "The percentage of plays that gained enough yards to keep the offense 'on schedule' toward getting a first down. Higher means a more consistently effective offense.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "14pt",
                      "color": "#14181f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Third Down %:  ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "14pt",
                      "color": "#4f46e5"
                    }
                  },
                  {
                    "value": "The percentage of third-down plays that resulted in a first down. A key measure of an offense's ability to keep drives alive (or a defense's ability to stop them).",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "14pt",
                      "color": "#14181f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Turnover Margin:  ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "14pt",
                      "color": "#4f46e5"
                    }
                  },
                  {
                    "value": "Takeaways (times the defense got the ball back) minus giveaways (times the offense lost the ball). Positive is good — it means the team gained more possessions than it lost.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "14pt",
                      "color": "#14181f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Win %:  ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "14pt",
                      "color": "#4f46e5"
                    }
                  },
                  {
                    "value": "The percentage of games won that season.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "14pt",
                      "color": "#14181f"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Offense vs. Defense metrics:  ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI Semibold",
                      "fontSize": "14pt",
                      "color": "#4f46e5"
                    }
                  },
                  {
                    "value": "\"Off_\" metrics describe how well a team's own offense performed — higher is better. \"Def_\" metrics describe how well a team's defense limited its opponent — for these, a lower (or more negative) number usually means a better defense.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "14pt",
                      "color": "#14181f"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
